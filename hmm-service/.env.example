# HMM Service Configuration

# Server settings
HMM_HOST=0.0.0.0
HMM_PORT=8002
HMM_WORKERS=1
HMM_LOG_LEVEL=INFO

# HMM database settings
HMM_PHROGS_DB_PATH=~/.phrogs/all_phrogs.h3m
HMM_E_VALUE_THRESHOLD=1e-5
# HMM_BIT_SCORE_THRESHOLD=  # Optional

# Processing settings
HMM_BATCH_SIZE=1000
HMM_CPUS=4
